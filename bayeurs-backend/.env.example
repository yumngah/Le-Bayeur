# DATABASE
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=Yum2422005
DB_NAME=Bayeur

# SERVER
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# EMAIL SERVICE (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_NAME=Bayeurs
SMTP_FROM_EMAIL=noreply@bayeurs.com

# SMS SERVICE (Twilio or local provider)
SMS_API_KEY=your_sms_api_key
SMS_ACCOUNT_SID=your_account_sid
SMS_PHONE_NUMBER=+237000000000

# FILE UPLOAD
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880  # 5MB in bytes

# PAYMENT GATEWAY (Stripe/Flutterwave)
PAYMENT_API_KEY=your_payment_api_key
PAYMENT_API_SECRET=your_payment_api_secret

# CORS
CORS_ORIGIN=http://localhost:3000,https://app.bayeurs.com

# LOG LEVEL
LOG_LEVEL=debug
